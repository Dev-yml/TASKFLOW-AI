# ═══════════════════════════════════════════════════════════════════════════
# CRM Backend - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
# 
# IMPORTANT: Copy this file to .env and fill in the actual values
# .env file is git-ignored and should NEVER be committed
#
# Location: crm-backend/.env
# 
# After editing:
# 1. Save the file
# 2. Restart the backend application
# 3. Verify settings in application logs
#
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# Spring Profile & Server Configuration
# ─────────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081

# ─────────────────────────────────────────────────────────────────────────
# Database Configuration (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────
DATABASE_NAME=crm_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password_here
# Tip: Use a strong password with mix of uppercase, lowercase, numbers, symbols
# Min 12 characters recommended

# ─────────────────────────────────────────────────────────────────────────
# JWT (JSON Web Token) Configuration
# ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_min_32_characters
# Tip: Generate with: openssl rand -base64 32
# Used for: User authentication, token signing
# Min 32 characters required

JWT_EXPIRATION=86400000
# Default: 86400000 (24 hours in milliseconds)

JWT_REFRESH_EXPIRATION=604800000
# Default: 604800000 (7 days in milliseconds)

JWT_ISSUER=crm-backend
# Default: crm-backend

# ─────────────────────────────────────────────────────────────────────────
# AI Configuration (xAI / Groq)
# ─────────────────────────────────────────────────────────────────────────
XAI_API_KEY=your_groq_api_key_here
# Get from: https://console.groq.com/keys
# Format: gsk_XXXXXXXXXXXX
# Used for: AI chat, AI insights, task recommendations

XAI_MODEL=grok-4.20-reasoning
# Default: grok-4.20-reasoning
# Alternatives: grok-1.5-turbo, mixtral-8x7b-32768

# ─────────────────────────────────────────────────────────────────────────
# OAuth2 Configuration - Google
# ─────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
# Get from: https://console.cloud.google.com
# Format: XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Get from: Same place as GOOGLE_CLIENT_ID
# Format: GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────
# OAuth2 Configuration - GitHub
# ─────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id_here
# Get from: https://github.com/settings/developers
# Register as OAuth App, fill in callback URL

GITHUB_CLIENT_SECRET=your_github_client_secret_here
# Get from: Same place as GITHUB_CLIENT_ID

# ─────────────────────────────────────────────────────────────────────────
# Email Configuration (Gmail SMTP)
# ─────────────────────────────────────────────────────────────────────────
MAIL_USERNAME=your_gmail_email@gmail.com
# Your Gmail address
# Used for: Sending invitation emails, notifications

MAIL_PASSWORD=your_gmail_app_password_here
# Get from: https://myaccount.google.com/apppasswords
# Steps:
#   1. Enable 2FA on Gmail account
#   2. Go to App Passwords (link above)
#   3. Select "Mail" and "Windows Computer"
#   4. Generate and copy the password here
# Note: This is NOT your Gmail password, it's a special app password

MAIL_HOST=smtp.gmail.com
# Default: smtp.gmail.com (Gmail SMTP server)

MAIL_PORT=587
# Default: 587 (TLS port for Gmail)

# ─────────────────────────────────────────────────────────────────────────
# Redis Configuration (Cache)
# ─────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
# Default: localhost (for local development)
# In Docker: redis (service name in docker-compose)

REDIS_PORT=6379
# Default: 6379 (standard Redis port)

REDIS_PASSWORD=
# Default: empty (no password for local)
# Set if Redis requires authentication

REDIS_DATABASE=0
# Default: 0 (first database)

# ─────────────────────────────────────────────────────────────────────────
# CORS & WebSocket Configuration
# ─────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
# Comma-separated list of allowed origins
# Used for: Frontend origin access control

WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
# Comma-separated list of allowed WebSocket origins
# Used for: Real-time chat, notifications

# ─────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARN, ERROR
# Debug = more verbose logging
# Info = standard logging
# Warn = only warnings and errors
# Error = only errors

# ─────────────────────────────────────────────────────────────────────────
# File Upload Configuration
# ─────────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10MB
# Default: 10MB (10485760 bytes)
# Max file size for task attachments

UPLOAD_DIR=uploads/task-attachments
# Default: uploads/task-attachments (relative to project root)
# Where uploaded files are stored

# ─────────────────────────────────────────────────────────────────────────
# Database Pool Configuration
# ─────────────────────────────────────────────────────────────────────────
DB_POOL_SIZE=10
# Default: 10 (max connections in pool)
# Higher for production

# ─────────────────────────────────────────────────────────────────────────
# Async Task Execution
# ─────────────────────────────────────────────────────────────────────────
ASYNC_CORE_POOL_SIZE=5
ASYNC_MAX_POOL_SIZE=10
ASYNC_QUEUE_CAPACITY=100

# ─────────────────────────────────────────────────────────────────────────
# Optional: Resend Email Service
# ─────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
# Get from: https://resend.com/api-keys
# Optional: For email service integration

RESEND_FROM_EMAIL=onboarding@resend.dev
# Default: onboarding@resend.dev
# Your verified sending email

# ═══════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env
#    Command: cp .env.example .env
#
# 2. Fill in the values:
#    - Use your actual email for MAIL_USERNAME
#    - Generate new passwords (don't use production passwords in dev)
#    - Get API keys from respective services
#    - Update origins to match your frontend URLs
#
# 3. DO NOT COMMIT .env
#    This file should stay local only
#    It will be automatically ignored by Git
#
# 4. Restart the backend
#    mvn spring-boot:run
#    or in your IDE
#
# 5. Verify in logs
#    Look for: "Application started"
#    Check for any config warnings
#
# ═══════════════════════════════════════════════════════════════════════════
# GETTING API KEYS GUIDE
# ═══════════════════════════════════════════════════════════════════════════
#
# GROQ API (XAI_API_KEY):
#   1. Visit https://console.groq.com/keys
#   2. Create account (free)
#   3. Copy API key
#
# Google OAuth (GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET):
#   1. Visit https://console.cloud.google.com
#   2. Create new project
#   3. Enable "Google+ API"
#   4. Create OAuth 2.0 credentials
#   5. Set authorized redirect URI: http://localhost:8081/login/oauth2/code/google
#   6. Copy Client ID and Secret
#
# GitHub OAuth (GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET):
#   1. Visit https://github.com/settings/developers
#   2. New OAuth App
#   3. Authorization callback URL: http://localhost:8081/login/oauth2/code/github
#   4. Copy Client ID and Secret
#
# Gmail App Password (MAIL_PASSWORD):
#   1. Enable 2-Step Verification on Gmail
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Windows Computer"
#   4. Generate app password
#   5. Copy the password (16 characters)
#
# ═══════════════════════════════════════════════════════════════════════════

