# ── Application ──────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_NAME=crm_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_PORT=5432
HIBERNATE_DDL_AUTO=update

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRATION=86400000

# ── AI (Groq) ────────────────────────────────────────────────────────────────
XAI_API_KEY=your_groq_api_key
XAI_MODEL=llama-3.3-70b-versatile
XAI_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# ── OAuth2 ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/callback

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
