            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Website Redesign\",\n  \"description\": \"Redesign company website with modern UI\",\n  \"workspaceId\": {{workspace_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/projects",
